@model HuaSect_AMS_DBTC.Models.AttendanceProfilePage
@{
    ViewData["Title"] = "Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Head {
    @* <link rel="stylesheet" href="~/css/Student.css" /> *@
}

<div class="container">
    <div class="page-title">MY ATTENDANCE</div>

    <!-- Info Card - Bound to Model -->
    <div class="info-card">
        <div class="info-title">@Model.Course.Name (@Model.Course.Code)</div>
        
        <div class="info-detail">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            @* Student: @Model.CurrentStudentName Add to model or use User.Identity *@
            Student: todo
        </div>
        
        <div class="info-detail">
            @* Instructor: @Model.Course.Instructor Add Instructor property to Course *@
            Instructor: todo
        </div>
        
        <div class="info-detail">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Schedule: @Model.Course.Schedule
        </div>
    </div>

    <!-- Stats Row - Calculated from AttendanceRecords -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-label">Total Sessions</div>
            <div class="stat-value">@Model.AttendanceRecords?.Count() ?? 0</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Present</div>
            <div class="stat-value">@Model.AttendanceRecords?.Count(a => a.Status == "Present") ?? 0</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Late</div>
            <div class="stat-value">@Model.AttendanceRecords?.Count(a => a.Status == "Late") ?? 0</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Absent</div>
            <div class="stat-value">@Model.AttendanceRecords?.Count(a => a.Status == "Absent") ?? 0</div>
        </div>
    </div>

    <!-- Attendance History List -->
    <div class="history-container">
        <div class="history-header">ATTENDANCE HISTORY</div>
        
        @* Show month badge if records exist *@
        @if (Model.AttendanceRecords?.Any() == true)
        {
            var firstRecord = Model.AttendanceRecords.OrderBy(a => a.Date).FirstOrDefault();
            @if (firstRecord != null)
            {
                <div class="month-badge">@firstRecord.Date.ToString("MMMM yyyy")</div>
            }
        }

        <div class="history-list">
            @if (Model.AttendanceRecords?.Any() == true)
            {
                @* Sort by date descending (newest first) *@
                @foreach (var record in Model.AttendanceRecords.OrderByDescending(a => a.Date))
                {
                    // Determine CSS class and SVG icon based on status
                    var statusClass = record.Status?.ToLower() ?? "absent";
                    var itemClass = $"item-{statusClass}";
                    
                    <div class="history-item @itemClass">
                        @* Conditional SVG icon based on status *@
                        @if (record.Status == "Present")
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        }
                        else if (record.Status == "Late")
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        }
                        
                        @* Formatted date: "Monday, February 15, 2026" *@
                        @record.Date.ToString("dddd, MMMM d, yyyy")
                    </div>
                }
            }
            else
            {
                <div class="history-item text-muted">No attendance records found for this course.</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @* <script src="~/js/LogIn.js"></script> *@
}