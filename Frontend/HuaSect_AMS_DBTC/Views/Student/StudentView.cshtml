using StudentManagement.Models;

namespace StudentManagement.Services
{
// ────────────────────────────────────────────────────────────────
// IStudentService — contract for all student-related data operations
// ────────────────────────────────────────────────────────────────
public interface IStudentService
{
Task<List<StudentModel>>      GetAllStudentsAsync();
Task<StudentModel?>           GetStudentByIdAsync(int id);
Task<StudentModel>            AddStudentAsync(StudentModel student);
Task<StudentModel>            UpdateStudentAsync(StudentModel student);
Task                          DeleteStudentAsync(int id);
Task<List<AttendanceDto>>     GetAttendanceByStudentIdAsync(int studentId);
Task<StudentListViewModel>    GetStudentListViewModelAsync(string? course, DateTime date);
Task                          SaveAttendanceAsync(List<AttendanceInputModel> records);
}

// ────────────────────────────────────────────────────────────────
// StudentService — in-memory implementation (swap for EF Core / DB)
// ────────────────────────────────────────────────────────────────
public class StudentService : IStudentService
{
