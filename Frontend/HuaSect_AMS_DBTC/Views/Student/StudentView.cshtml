new StudentModel { Id=2, FirstName="Julia",       MiddleName="Yashika", LastName="Kong",   StudentId="2024-0002", StudentNo="5", YearLevel="2", CourseId="BSIT", Email="julia@school.edu" },
new StudentModel { Id=3, FirstName="Maverick",    LastName="Tajanlangit",                   StudentId="2024-0003", StudentNo="4", YearLevel="2", CourseId="BSIT", Email="maverick@school.edu" },
new StudentModel { Id=4, FirstName="Leon",        MiddleName="S.", LastName="Kennedy",     StudentId="2024-0004", StudentNo="3", YearLevel="3", CourseId="BSIT", Email="leon@school.edu" },
new StudentModel { Id=5, FirstName="Ada",         MiddleName="A.", LastName="Wong",        StudentId="2024-0005", StudentNo="2", YearLevel="4", CourseId="ME",   Email="ada@school.edu" },
