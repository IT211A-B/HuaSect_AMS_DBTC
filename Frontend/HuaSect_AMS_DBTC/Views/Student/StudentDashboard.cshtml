@model HuaSect_AMS_DBTC.Models.StudentDashboardPage
@{
    ViewData["Title"] = "Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Head {
    @* <link rel="stylesheet" href="~/css/Student.css" /> *@
}

@section NavWelcomeMsg {
    <div class="welcome-badge">Welcome Back, Dench Mery!</div>
}

@section NavHeader {
    TEACHER DASHBOARD
}

<div class="container">
    <!-- Search Bar with Tag Helper for form submission -->
    <div class="search-bar">
        <form method="get" asp-page-handler="Search" class="search-input">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                 stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" name="SearchQuery" placeholder="Search by Course or Roll No" />
        </form>
    </div>

    <div class="section-label">MY COURSE</div>

    <div class="course-list">
        @if (Model.Courses?.Any() == true)
        {
            @foreach (var course in Model.Courses)
            {
                <div class="course-card">
                    <div class="course-header">
                        <div class="course-title">@course.Name</div>
                        <div class="course-code">@course.Code</div>
                    </div>
                    <div class="course-body">
                        <div class="course-info">
                            <!-- Add Instructor property to Course model for dynamic display -->
                            @* Faculty: @course.Instructor <br> *@
                            Faculty: todo <br>
                            @course.Schedule
                        </div>
                        
                        <a asp-controller="Teacher" asp-action="AttendanceHistory" asp-route-courseCode="@course.Code" class="btn-history">View Attendance History</a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">
                <p>No courses assigned yet.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    @* <script src="~/js/LogIn.js"></script> *@
}