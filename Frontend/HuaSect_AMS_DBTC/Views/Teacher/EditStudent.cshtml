@* @model HuaSect_AMS_DBTC.Models.TeacherDashboardViewModel *@
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveNav"] = "home";
}

@section Head {
    @* <link rel="stylesheet" href="~/css/Student.css" /> *@
}

<div class="modal-overlay">
    <div class="modal-container">
        <div class="modal-header">
            <div class="icon-circle">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                    <path
                    d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                </svg>
            </div>
            <div class="student-name">Mikhael Roso Santos</div>
        </div>

        <div class="form-group">
            <span class="form-label">Name:</span>
            <input type="text" class="form-value" value="Mikhael Roso Santos">
        </div>

        <div class="form-group">
            <span class="form-label">Course:</span>
            <input type="text" class="form-value" value="BS Information Technology">
        </div>

        <div class="form-group">
            <span class="form-label">Year:</span>
            <input type="text" class="form-value" value="2nd Year">
        </div>

        <div class="form-group">
            <span class="form-label">ID No.:</span>
            <input type="text" class="form-value" value="10843795379">
        </div>

        <div class="form-actions">
            <button class="btn btn-edit">Edit</button>
            <button class="btn btn-cancel">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
    @* <script src="~/js/LogIn.js"></script> *@
}