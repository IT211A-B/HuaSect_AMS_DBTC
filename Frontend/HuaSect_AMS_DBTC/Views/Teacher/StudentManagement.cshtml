@* @model HuaSect_AMS_DBTC.Models.TeacherDashboardViewModel *@
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveNav"] = "home";
}

@section Head {
    @* <link rel="stylesheet" href="~/css/Student.css" /> *@
}

@section NavHeader {
    TEACHERS DASHBOARD
}

@section NavUsername {
    Dench Caballero
}

@section NavRole {
