@model HuaSect_AMS_DBTC.Models.StudentManagementPage
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveNav"] = "home";
}

@section Head {
    @* <link rel="stylesheet" href="~/css/Student.css" /> *@
}

@section NavHeader {
    TEACHERS DASHBOARD
}

@section NavUsername {
    Dench Caballero
}

@section NavRole {
    Teacher
}

<div class="container">
    <div class="search-bar">
        <div class="search-input">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                 stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" placeholder="Search by Name or Roll No">
        </div>
        <div class="btn btn-add"><a asp-controller="Teacher" asp-action="AddStudent">Add Student</a></div>
        <div class="btn btn-attendance"><a>Take Attendance</a></div>
    </div>

    <div class="cards-grid">
    @if (Model.Students?.Any() == true)
    {
        @foreach (var student in Model.Students)
        {
            <div class="card-wrapper">
                <div class="student-card">
                    <div class="card-header">
                        <div class="student-name">@student.Name</div>
                        <div class="student-roll">@student.Field - @student.Year</div>
                        <div class="student-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="card-actions">
                            <div class="btn-history">
                                <a asp-controller="Teacher" asp-action="AttendanceTracker" asp-route-studentName="@student.Name">View Attendance History</a>\
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Optional: Uncomment dropdown for Edit/Delete actions -->
                @* <div class="dropdown-menu">
                    <a asp-controller="Teacher" asp-action="EditStudent" class="dropdown-item">Update</a>
                    <form asp-controller="Teacher" asp-action="DeleteStudent" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Delete @student.Name?')">Delete</button>
                    </form>
                </div> *@
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-5">
            <p>No students found.</p>
        </div>
    }
</div>
</div>

@section Scripts {
    @* <script src="~/js/LogIn.js"></script> *@
}