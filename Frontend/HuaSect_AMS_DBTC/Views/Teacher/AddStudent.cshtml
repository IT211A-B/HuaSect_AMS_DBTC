@* @model HuaSect_AMS_DBTC.Models.TeacherDashboardViewModel *@
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveNav"] = "home";
}

@section Head {
    @* <link rel="stylesheet" href="~/css/Student.css" /> *@
}

@section NavHeader {
    ADD STUDENT
}

@section NavUsername {
    Dench Caballero
}

@section NavRole {
    Student
}

<div>
    <div class="modal-container">
        <div class="modal-header">
            <div class="icon-circle">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="capGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#3a3a6c" />
                            <stop offset="100%" style="stop-color:#2a2a4c" />
                        </linearGradient>
                    </defs>
                    <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3z" fill="url(#capGrad)" />
                    <path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z" fill="#2a2a4c" />
                    <rect x="11" y="17" width="2" height="4" fill="#c4956a" />
                    <circle cx="12" cy="22" r="1.5" fill="#c4956a" />
                </svg>
            </div>
            <div class="modal-title">ADD STUDENT</div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <input type="text" class="form-input" placeholder="First Name:">
            </div>
            <div class="form-group">
                <input type="text" class="form-input" placeholder="Student ID:">
            </div>
            <div class="form-group">
                <input type="text" class="form-input" placeholder="Middle Name:">
            </div>
            <div class="form-group">
                <input type="text" class="form-input" placeholder="Student No.:">
            </div>
            <div class="form-group">
                <input type="text" class="form-input" placeholder="Last Name:">
            </div>
            <div class="form-group">
                <input type="text" class="form-input" placeholder="Year Level:">
            </div>
            <div class="form-group">
                <input type="text" class="form-input" placeholder="Email:">
            </div>
            <div class="form-group">
                <input type="text" class="form-input" placeholder="Course ID:">
            </div>
        </div>

        <div class="form-actions">
            <div class="btn btn-add">Add</div>
            <div class="btn btn-cancel"><a asp-controller="Teacher" asp-action="StudentManagement">Cancel</a></div>
        </div>
    </div>
</div>

@section Scripts {
    @* <script src="~/js/LogIn.js"></script> *@
}